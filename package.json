{
  "name": "next-inline-editor",
  "version": "0.1.0",
  "description": "Zero-config inline content editor for Next.js sites backed by GitHub. Edit text and images directly on your live pages.",
  "keywords": [
    "nextjs",
    "cms",
    "inline-editing",
    "github",
    "content"
  ],
  "license": "MIT",
  "author": "madebytie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebytie/next-inline-editor.git"
  },
  "homepage": "https://github.com/madebytie/next-inline-editor#readme",
  "bugs": {
    "url": "https://github.com/madebytie/next-inline-editor/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api/login": "./dist/api/login.js",
    "./api/save": "./dist/api/save.js",
    "./api/upload": "./dist/api/upload.js",
    "./api/logout": "./dist/api/logout.js"
  },
  "bin": {
    "next-inline-editor": "dist/bin/init.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
